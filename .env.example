# Copy to .env before running `docker compose up`.
# Everything has a working default — the only thing you may want to add
# is a real provider key. Without one, the app runs on the built-in
# "mock" provider so you can still try the full pipeline offline.

# ---- LLM providers ---------------------------------------------------
# Add your OpenAI key here to enable the GPT models in the UI.
OPENAI_API_KEY=
# Optional second provider (multi-provider demo).
ANTHROPIC_API_KEY=

# ---- ingestion auth --------------------------------------------------
# Shared secret the SDK presents to the ingestion API. Keep the default
# for local runs; rotate it for anything real.
INGEST_API_KEY=local-dev-ingest-key

# ---- infra (defaults are fine for docker compose) --------------------
POSTGRES_USER=inferlog
POSTGRES_PASSWORD=inferlog
POSTGRES_DB=inferlog
